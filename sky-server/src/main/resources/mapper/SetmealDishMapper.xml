<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sky.mapper.SetmealDishMapper">
    <insert id="insertBatch">
        insert into setmeal_dish (setmeal_id, dish_id, name, price, copies) values
        <foreach item="dish" collection="list" separator=",">
            (#{dish.setmealId}, #{dish.dishId}, #{dish.name}, #{dish.price}, #{dish.copies})
        </foreach>
    </insert>
    <update id="update">
        update setmeal_dish
        <set>
            <if test="name != null">
                name = #{name},
            </if>
            <if test="categoryId != null">
                category_id = #{categoryId},
            </if>
            <if test="price != null">
                price = #{price},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="description != null">
                description = #{description},
            </if>
            <if test="image != null">
                image = #{image},
            </if>
            <if test="updateTime != null">
                update_time = #{updateTime},
            </if>
            <if test="updateUser != null">
                update_user = #{updateUser}
            </if>
        </set>
        where if=#{id}
    </update>
    <delete id="deleteSetmealDishAll">
        delete from setmeal_dish where setmeal_id in
         <foreach item="id" collection="ids" separator="," open="(" close=")">
             #{id}
         </foreach>

    </delete>


    <select id="getSetmealIdsByDishIds" resultType="java.lang.Long">
        select setmal_id from setmeal_dish where dish_id in
       <foreach item="dishId" collection="dishIds" separator="," open="(" close=")">
           #{dishId}
       </foreach>
    </select>
</mapper>
